<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- The Roslyn build that ships inside the .NET SDK is published here, not on nuget.org.
         We need the exact compiler version so that the SDK's source generators (notably the
         Razor generator) can be instantiated and run inside our process. -->
    <add key="dotnet-tools"
         value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="dotnet-tools">
      <package pattern="Microsoft.CodeAnalysis*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <!-- Transitive Roslyn packages (e.g. Microsoft.CodeAnalysis.Analyzers) may only exist
           on nuget.org, so allow this prefix from here too. -->
      <package pattern="Microsoft.CodeAnalysis*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
